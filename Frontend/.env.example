# Mapbox token - for LOCAL development only.
# 1. Copy this file to .env.local (do NOT commit .env.local).
# 2. Replace the value below with your token from https://account.mapbox.com/access-tokens/
# 3. For online/preview deployments (Vercel, Netlify, etc.): do NOT set this variable.
#    The map will show a "add token" message and no Mapbox requests = no token usage.
VITE_MAPBOX_ACCESS_TOKEN=your_token_here

# Optional base URL for backend API (development only)
# frontend uses this when making requests to /api/...
# e.g. http://localhost:3000
VITE_API_BASE=

# Supabase configuration (anon key for client-side auth/data)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
